# ======= Supabase / PostgreSQL 連線設定 =======
# 請將這裡的字串替換為您從 Supabase 取得的 Transaction pooler 連線字串
# 格式大約為: postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]"

# ======= 其他可選設定 =======
# 伺服器 JWT 密鑰，若不設定會自動產生隨機字串
DS_SECRET="your-super-secret-key-for-jwt"

# 後台儀表板的密碼 (預設為 dinnerswipe-admin-2024)
DS_ADMIN="dinnerswipe-admin-2024"
